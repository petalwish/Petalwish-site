---
import ThirtyMoleculesCloud from './ThirtyMoleculesCloud';
---

<section class="about-shell" aria-label="About me molecule cloud">
	<div class="molecule-stage" aria-hidden="true">
		<ThirtyMoleculesCloud client:only="react" />
	</div>
</section>

<style>
	.about-shell {
		position: relative;
		width: 100%;
		min-height: 100dvh;
		display: grid;
		place-items: center;
		padding-inline: clamp(1.25rem, 4vw, 3rem);
		padding-block: 0;
	}

	.molecule-stage {
		position: relative;
		width: 100%;
		height: 100dvh;
		pointer-events: none;
	}
</style>
