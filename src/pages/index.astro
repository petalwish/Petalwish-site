---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const sections = [
	{ id: 'hero', label: 'Hero' },
	{ id: 'lab-clusters', label: '核心展厅' },
	{ id: 'blog', label: 'Blog' },
	{ id: 'outro', label: '履历&联系' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="home-page">
		<div class="home-bg" aria-hidden="true">
			<div class="home-bg-dna-glow"></div>
		</div>

		<header class="home-topbar">
			<a href="/" class="topbar-logo-slot" aria-label="首页">
				<span class="topbar-logo-dot" aria-hidden="true"></span>
			</a>
			<nav class="topbar-nav" aria-label="Homepage sections">
				{
					sections.map((section) => (
						<a href={`#${section.id}`} class="topbar-link">
							{section.label}
						</a>
					))
				}
			</nav>
		</header>

		<main class="home-main">
			{
				sections.map((section) => (
					<section id={section.id} class="home-section">
						<div class="section-shell">
							<span class="section-chip">{section.label}</span>
						</div>
					</section>
				))
			}
		</main>
	</body>
</html>
