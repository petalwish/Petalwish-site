---
import BaseHead from '../components/BaseHead.astro';
import Hero from '../components/hero/Hero';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

/** 首屏 HERO 不设顶栏锚点；其余分区在顶栏右侧跳转 */
const navSections = [
	{ id: 'about-me', label: 'ABOUT ME' },
	{ id: 'project', label: 'PROJECT' },
	{ id: 'blog', label: 'BLOG' },
	{ id: 'exploration', label: 'EXPLORATION' },
	{ id: 'contact', label: 'CONTACT' },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="home-page">
		<div class="home-bg" aria-hidden="true"></div>

		<header class="home-topbar">
			<a href="/" class="topbar-logo-slot" aria-label="首页">
				<span class="topbar-logo-dot" aria-hidden="true"></span>
			</a>
			<nav class="topbar-nav" aria-label="Page sections">
				{
					navSections.map((section) => (
						<a href={`#${section.id}`} class="topbar-link">
							{section.label}
						</a>
					))
				}
			</nav>
		</header>

		<main class="home-main">
			<section id="hero" class="home-section home-section-hero" aria-label="首屏">
				<Hero client:only="react" />
			</section>
			{navSections.map((section) => <section id={section.id} class="home-section" aria-label={section.label} />)}
		</main>
	</body>
</html>
